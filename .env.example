# Slack (required for the bot). For Gmail image attachments in DMs, add scope: files:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Firebase (for study + email subscriptions). Use one of:
#   FIREBASE_CREDENTIALS_JSON='{"type":"service_account",...}'   (JSON one-liner; no file)
#   FIREBASE_CREDENTIALS_PATH=firebase-credentials.json        (path to file)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Gmail filter (optional; leave unset to disable). Use one of:
#   GMAIL_CREDENTIALS_JSON='{"installed":{"client_id":"...",...}}'   (JSON one-liner; no file)
#   GMAIL_CREDENTIALS_PATH=gmail-credentials.json                   (path to file)
GMAIL_MONITORED_EMAIL=ctc-uci@gmail.com
GMAIL_CREDENTIALS_PATH=gmail-credentials.json
GMAIL_TOKEN_PATH=gmail-token.json
GMAIL_HISTORY_PATH=gmail-history-id.txt
# Set to 1 when running without a display (server, Docker, SSH): skips opening a browser for first-time auth
# GMAIL_HEADLESS=1
# For Railway/public URL OAuth: set base URL (e.g. https://your-app.up.railway.app) or leave unset to use RAILWAY_PUBLIC_DOMAIN
# GMAIL_REDIRECT_URI=https://your-app.up.railway.app
OAUTHLIB_INSECURE_TRANSPORT=1

# MATCHY_CHANNEL_ID=C01FL4VCE1Z
